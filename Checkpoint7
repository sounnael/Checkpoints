
import requests
from bs4 import BeautifulSoup
from urllib.parse import urljoin
import time

class WikipediaScraper:
    def __init__(self):
        self.session = requests.Session()
        self.session.headers.update({
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
        })
    
    def get_html_content(self, url):
        """Get and parse HTML content from a Wikipedia page"""
        try:
            response = self.session.get(url, timeout=10)
            response.raise_for_status()
            return BeautifulSoup(response.content, 'html.parser')
        except Exception as e:
            print(f"Error: {e}")
            return None
    
    def extract_title(self, soup):
        """Extract article title"""
        title_tag = soup.find('h1', {'class': 'firstHeading'})
        return title_tag.get_text().strip() if title_tag else "Unknown"
    
    def extract_content(self, soup):
        """Extract article text with headings mapped to paragraphs"""
        content = {}
        main = soup.find('div', {'id': 'mw-content-text'})
        
        if not main:
            return content
        
        current_header = "Introduction"
        current_text = []
        
        for tag in main.find_all(['h2', 'h3', 'h4', 'p']):
            if tag.name in ['h2', 'h3', 'h4']:
                if current_text:
                    content[current_header] = ' '.join(current_text)
                current_header = tag.get_text().replace('[edit]', '').strip()
                current_text = []
            elif tag.name == 'p':
                text = tag.get_text().strip()
                if text and not text.startswith('Jump to navigation'):
                    current_text.append(text)
        
        if current_text:
            content[current_header] = ' '.join(current_text)
        
        return content
    
    def extract_links(self, soup, base_url):
        """Collect internal Wikipedia links"""
        links = set()
        for link in soup.find_all('a', href=True):
            href = link['href']
            if href.startswith('/wiki/') and ':' not in href and 'Main_Page' not in href:
                full_url = urljoin(base_url, href)
                links.add(full_url)
        return sorted(list(links))
    
    def scrape(self, url):
        """Main function that wraps everything"""
        print(f"\nScraping: {url}")
        
        soup = self.get_html_content(url)
        if not soup:
            return None
        
        return {
            'url': url,
            'title': self.extract_title(soup),
            'content': self.extract_content(soup),
            'links': self.extract_links(soup, url)
        }


# Question 1  
# Write a Python program that multiplies all the items in a list.

list1 = [2, 3, 6]
list2 = [10, 1.5, 5]

result1 = 1
result2 = 1

for nb in list1:
    result1 = result1 * nb

for nb in list2:
    result2 = result2 * nb

print (f"Product result of {list1} is: {result1}")
print (f"Product result of {list2} is: {result2}")

# Question 2
# Write a Python program to get a list, sorted in increasing order by the last element in each tuple, from a given list of non-empty tuples.

unordered_list = [(2, 5), (1, 2), (4, 4), (2, 3), (2, 1)]
ordered_list = sorted(unordered_list, key = lambda x: x[-1])
print(f"The ordered list is: {ordered_list}")

# Question 3 
# Write a Python program that combines two dictionaries by adding values for common keys.
d1 = {"x": 5, "y": 12, "r": 8, "z": 7}
d2 = {"x": 14, "y": 9, "h": 3} 
dresult = d1.copy()
for key in d2:
    if key in dresult:
        dresult[key] = d1[key] + d2[key]
    else:
        dresult[key] = d2[key]
print(f"The result is: {dresult}")
 

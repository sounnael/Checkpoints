# ==================== KEY ERROR ====================
# Original (Error):
# mydictionary = {True: "hello", False: "bye", '3': 'python'}
# mydictionary['True']  # KeyError: 'True'

# Rectified:
mydictionary = {True: "hello", False: "bye", '3': 'python'}

# Access with correct key type (Boolean True, not string 'True')
print(mydictionary[True])  # Output: hello

# Or check if key exists before accessing
key_to_find = 'True'
if key_to_find in mydictionary:
    print(mydictionary[key_to_find])
else:
    print(f"Key '{key_to_find}' not found")


# ==================== INDENTATION ERROR ====================
# Original (Error):
# i = 14
# while i < 78:
#     print(i)  # IndentationError: expected an indented block
#     i += 1

# Rectified:
i = 14
while i < 78:
    print(i)  # Must be indented (usually 4 spaces or a tab)
    i += 1


# ==================== STOPITERATION ERROR ====================
# Original (Error):
# it = iter([1, 2, 3])
# next(it)  # 1
# next(it)  # 2
# next(it)  # 3
# next(it)  # StopIteration error

# Rectified:
it = iter([1, 2, 3])
print(next(it))  # 1
print(next(it))  # 2
print(next(it))  # 3

# Use try-except to handle StopIteration gracefully
try:
    print(next(it))  # Will raise StopIteration
except StopIteration:
    print("No more items in iterator")

# Alternative: Use for loop which handles StopIteration automatically
it2 = iter([1, 2, 3])
for item in it2:
    print(item)


# ==================== TYPE ERROR ====================
# Original (Error):
# '15' + 15  # TypeError: cannot concatenate 'str' and 'int' objects

# Rectified:
# Option 1: Convert string to int
result1 = int('15') + 15
print(result1)  # Output: 30

# Option 2: Convert int to string
result2 = '15' + str(15)
print(result2)  # Output: '1515'


# ==================== VALUE ERROR ====================
# Original (Error):
# int('python')  # ValueError: invalid literal for int() with base 10: 'python'

# Rectified:
# Option 1: Only convert strings that represent valid integers
valid_number = int('123')  # Works fine
print(valid_number)  # Output: 123

# Option 2: Use try-except to handle invalid conversions
try:
    result = int('python')
except ValueError as e:
    print(f"Cannot convert: {e}")
    result = None


# ==================== NAME ERROR ====================
# Original (Error):
# python  # NameError: name 'python' is not defined

# Rectified:
# Define the variable first
python = "Python is awesome!"
print(python)  # Output: Python is awesome!

# Or use a string literal
print("python")


# ==================== ZERO DIVISION ERROR ====================
# Original (Error):
# x = 19 / 0  # ZeroDivisionError: division by zero

# Rectified:
# Check denominator before division
denominator = 0
if denominator != 0:
    x = 19 / denominator
else:
    print("Cannot divide by zero")
    x = float('inf')  # Or set to a default value

# ==================== INDEX ERROR ====================
# Original (Error):
# mylist=[14, "hello", 967]
# mylist[6]  # IndexError: list index out of range

# Rectified:
mylist = [14, "hello", 967]
# Access only valid indices (0, 1, 2)
print(mylist[2])  # Output: 967
# Or check length before accessing
if len(mylist) > 6:
    print(mylist[6])
else:
    print(f"List has only {len(mylist)} elements")



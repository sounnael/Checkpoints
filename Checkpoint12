import tkinter as tk

def fahrenheit_to_celsius():
    """Convert Fahrenheit to Celsius and display the result"""
    try:
        # Get the temperature from entry widget and convert to float
        fahrenheit = float(ent_temperature.get())
        
        # Convert to Celsius: (°F - 32) × 5/9
        celsius = (fahrenheit - 32) * 5/9
        
        # Round to 2 decimal places
        celsius_rounded = round(celsius, 2)
        
        # Update the result label with the converted value
        lbl_result.config(text=f"{celsius_rounded} \N{DEGREE CELSIUS}")
    
    except ValueError:
        # Handle invalid input (non-numeric values)
        lbl_result.config(text="Invalid input!\nEnter a number")

# Create the main window
window = tk.Tk()
window.title("Temperature Converter")
window.resizable(width=False, height=False)

# Create frame to hold entry and label
frm_entry = tk.Frame(master=window)

# Create entry widget for Fahrenheit input
ent_temperature = tk.Entry(master=frm_entry, width=10)

# Create label for degree Fahrenheit symbol
lbl_temp = tk.Label(master=frm_entry, text="\N{DEGREE FAHRENHEIT}")

# Arrange entry and label in the frame using grid
ent_temperature.grid(row=0, column=0, sticky="e")
lbl_temp.grid(row=0, column=1, sticky="w")

# Create conversion button
btn_convert = tk.Button(
    master=window,
    text="\N{RIGHTWARDS BLACK ARROW}",
    command=fahrenheit_to_celsius
)

# Create label to display the result
lbl_result = tk.Label(master=window, text="\N{DEGREE CELSIUS}")

# Arrange all widgets in the main window using grid
frm_entry.grid(row=0, column=0, padx=10)
btn_convert.grid(row=0, column=1, pady=10)
lbl_result.grid(row=0, column=2, padx=10)

# Start the GUI application
window.mainloop()

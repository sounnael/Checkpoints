    def load_device_data(self):
        """Load device data (try cache first, then web, then local)"""
        
        # First, try to load from local JSON cache
        if self.load_from_cache():
            self.status_label.config(
                text="✅ Loaded from local cache. Click 'Refresh from Web' for latest data!",
                fg="#2ecc71"
            )
            self.show_random_device()
        else:
            # If no cache, try web scraping
            self.refresh_from_web()
    
    def load_from_cache(self):
        """Load previously saved data from JSON file"""
        try:
            if os.path.exists("medical_devices_cache.json"):
                with open("medical_devices_cache.json", "r", encoding="utf-8") as f:
                    self.devices = json.load(f)
                self.source_label.config(text="📁 Data source: Local cache file")
                return True
        except Exception as e:
            print(f"Cache load error: {e}")
        return False
    
    def save_to_cache(self):
        """Save current devices to JSON cache"""
        try:
            with open("medical_devices_cache.json", "w", encoding="utf-8") as f:
                json.dump(self.devices, f, indent=2, ensure_ascii=False)
            return True
        except Exception as e:
            print(f"Cache save error: {e}")
            return False
    
    def refresh_from_web(self):
        """Scrape medical device data from websites"""
        
        # Update UI to show scraping in progress
        self.random_btn.config(state="disabled")
        self.refresh_btn.config(state="disabled", text="🔄 SCRAPING...")
        self.status_label.config(text="🌐 Web scraping in progress... Fetching medical device data", fg="#f39c12")
        self.progress_label.config(text="🕸️ Scraping data from web... Please wait")
        self.root.update()
        
        # Try multiple data sources
        devices_list = []
        
        # SOURCE 1: Wikipedia Medical Devices Page
        devices_list.extend(self.scrape_wikipedia_medical_devices())
        
        # SOURCE 2: FDA Medical Devices (simulated - real scraping would need API)
        devices_list.extend(self.get_fda_medical_devices())
        
        # SOURCE 3: WHO Medical Devices
        devices_list.extend(self.scrape_who_medical_devices())
        
        # Remove duplicates (based on device name)
        unique_devices = {}
        for device in devices_list:
            if device['name'] not in unique_devices:
                unique_devices[device['name']] = device
        
        self.devices = list(unique_devices.values())
        
        # If web scraping didn't get enough data, use backup
        if len(self.devices) < 5:
            self.use_backup_database()
            self.status_label.config(
                text="⚠️ Web scraping limited. Using backup database. Check internet connection.",
                fg="#e74c3c"
            )
        else:
            # Save to cache
            self.save_to_cache()
            self.status_label.config(
                text=f"✅ Web scraping complete! Loaded {len(self.devices)} medical devices from web sources",
                fg="#2ecc71"
            )
            self.source_label.config(text="🌐 Data source: Web scraping (Wikipedia, FDA, WHO)")
        
        # Reset UI
        self.random_btn.config(state="normal")
        self.refresh_btn.config(state="normal", text="🔄 REFRESH FROM WEB")
        self.progress_label.config(text="")
        
        # Show first device
        if self.devices:
            self.show_random_device()
        else:
            messagebox.showwarning("No Data", "Could not retrieve data. Using backup database.")
            self.use_backup_database()
            self.show_random_device()
    
    def scrape_wikipedia_medical_devices(self):
        """Scrape medical device information from Wikipedia"""
        devices = []
        
        try:
            # Wikipedia page about medical devices
            url = "https://en.wikipedia.org/wiki/Medical_device"
            headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'}
            
            response = requests.get(url, headers=headers, timeout=10)
            
            if response.status_code == 200:
                soup = BeautifulSoup(response.content, 'html.parser')
                
                # Find medical device categories in the page
                categories = soup.find_all('a', href=True)
                
                # Keywords to identify medical devices
                medical_keywords = ['ventilator', 'defibrillator', 'pacemaker', 'stethoscope', 
                                   'ultrasound', 'mri', 'ct scanner', 'x-ray', 'endoscope',
                                   'dialysis', 'infusion pump', 'monitor', 'ecg', 'ekg']
                
                for link in categories[:50]:  # Limit to first 50 links
                    text = link.get_text().lower()
                    
                    for keyword in medical_keywords:
                        if keyword in text and len(text) > 3:
                            device_info = self.get_device_details(keyword.title())
                            if device_info and device_info not in devices:
                                devices.append(device_info)
                            break
                            
        except Exception as e:
            print(f"Wikipedia scraping error: {e}")
        
        return devices
    

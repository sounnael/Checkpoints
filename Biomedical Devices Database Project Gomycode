    def save_to_file(self):
        """Save current device database to JSON file"""
        if not self.devices:
            messagebox.showwarning("No Data", "No data to save!")
            return
        
        try:
            filename = f"medical_devices_export_{random.randint(1000, 9999)}.json"
            with open(filename, "w", encoding="utf-8") as f:
                json.dump(self.devices, f, indent=2, ensure_ascii=False)
            
            messagebox.showinfo(
                "Save Successful",
                f"✅ Saved {len(self.devices)} devices to {filename}"
            )
            self.status_label.config(text=f"💾 Saved database to {filename}", fg="#e67e22")
        except Exception as e:
            messagebox.showerror("Save Error", f"Could not save file: {e}")


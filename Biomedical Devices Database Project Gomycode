    def scrape_who_medical_devices(self):
        """Scrape WHO medical device information"""
        devices = []
        
        try:
            # WHO medical devices page
            url = "https://www.who.int/health-topics/medical-devices"
            headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'}
            
            response = requests.get(url, headers=headers, timeout=10)
            
            if response.status_code == 200:
                soup = BeautifulSoup(response.content, 'html.parser')
                
                # Extract device information from the page
                device_sections = soup.find_all(['h1', 'h2', 'h3', 'p'])
                
                who_devices = [
                    'Diagnostic imaging equipment',
                    'Surgical instruments',
                    'Life support devices',
                    'Medical laboratory equipment'
                ]
                
                for device_name in who_devices:
                    devices.append({
                        'name': device_name,
                        'category': 'WHO Classification',
                        'description': f'{device_name} - Essential medical equipment recognized by World Health Organization',
                        'applications': 'Global Healthcare Systems',
                        'tech_specs': 'WHO standards compliant',
                        'source': 'WHO'
                    })
                    
        except Exception as e:
            print(f"WHO scraping error: {e}")
        
        return devices
    
